{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clove.dev/schema/v1/comment-list.json",
  "title": "clove comment list envelope",
  "description": "The `clove comments <id>` response.",
  "type": "object",
  "required": ["v", "ok", "data"],
  "properties": {
    "v": { "const": 1 },
    "ok": { "const": true },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["author", "timestamp", "body"],
        "properties": {
          "author": { "type": "string" },
          "timestamp": { "type": "string" },
          "body": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "_meta": { "type": "object" }
  },
  "additionalProperties": false
}
