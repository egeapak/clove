{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clove.dev/schema/v1/item-list.json",
  "title": "clove item list envelope",
  "description": "A list response. Each element carries at least the lean list fields (id, status, type, priority, title); the file-scan path additionally includes the full frontmatter, the index path does not.",
  "type": "object",
  "required": ["v", "ok", "data"],
  "properties": {
    "v": { "const": 1 },
    "ok": { "const": true },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status", "type", "priority", "title"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9]{0,7}-[0-9A-Z]{8}$" },
          "status": { "enum": ["open", "in_progress", "closed"] },
          "type": { "enum": ["bug", "feature", "chore", "docs", "epic"] },
          "priority": { "type": "integer", "minimum": 0, "maximum": 4 },
          "title": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "_meta": { "type": "object" }
  },
  "additionalProperties": false
}
